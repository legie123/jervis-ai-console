{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "staticDistDir": "./apps/web/dist",
      "settings": {
        "onlyCategories": ["accessibility"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }]
      }
    }
  }
}
