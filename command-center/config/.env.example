# Vite dev proxies /api and /webhooks to this origin (npm run dev:local / dev:web).
JARVIS_OPERATOR_ORIGIN=http://127.0.0.1:4317

# --- Cloud / static UI split (see docs/DEPLOY_CLOUD_RU.md) ---
# Build web with absolute API base (no trailing slash), e.g. https://api.example.com:4317
# VITE_OPERATOR_API_ORIGIN=
# Operator listen address (use 0.0.0.0 on a VPS so the port is reachable).
JARVIS_HTTP_HOST=127.0.0.1
# Exact Origin of static site for CORS (required if UI host ≠ API host).
# JARVIS_CORS_ALLOW_ORIGIN=

JARVIS_HOME=/Users/user/projects/JARVIS_COMMAND_CENTER
JARVIS_MODE=local
JARVIS_DATA_PROFILE=live
JARVIS_AUDIT_LOG=./data/live/logs/audit.jsonl
JARVIS_DRAFT_STORE=./data/live/drafts/whatsapp-drafts.json
JARVIS_MEMORY_STORE=./data/live/memory/local-memory.json
JARVIS_MISSION_STORE=./data/live/memory/missions.json
JARVIS_INBOX_STORE=./data/live/memory/whatsapp-inbox.json
JARVIS_SCHEDULER_STORE=./data/live/drafts/scheduled-jobs.json
# Adapter feeds power the Command Center unified inbox (/api/*/feed).
# Enable Obsidian + Ruflo agents + GoodMood (and Hermes) together, e.g.:
#   JARVIS_ADAPTERS_ENABLED=obsidian,ruflo,good_mood,hermes
# Or set each JARVIS_ADAPTER_*_ENABLED=true. Feeds read the audit log; tag events with
# source/action containing obsidian | ruflo,swarm,claude_flow | good_mood,coach,mood | hermes,handoff.
JARVIS_ADAPTERS_ENABLED=
JARVIS_ADAPTER_OBSIDIAN_ENABLED=false
# Ruflo Agents: recommended true (UI always polls /api/ruflo/feed on inbox refresh).
JARVIS_ADAPTER_RUFLO_ENABLED=false
# Hermes dispatch: recommended true (UI always polls /api/hermes/feed).
JARVIS_ADAPTER_HERMES_ENABLED=false
# GoodMood: recommended true (UI always polls /api/good-mood/feed on inbox refresh).
JARVIS_ADAPTER_GOOD_MOOD_ENABLED=false
JARVIS_INTENT_ROUTER_MODE=hybrid
JARVIS_INTENT_ROUTER_MIN_CONFIDENCE=0.65
JARVIS_CONFIRM_TOKEN_TTL_MS=120000
JARVIS_CONFIRM_TOKEN_MAX_TTL_MS=900000
JARVIS_RESTORE_CONFIRM_TOKEN=RESTORE_JARVIS
OBSIDIAN_VAULT_PATH=
OBSIDIAN_WRITE_ENABLED=false
OBSIDIAN_SYNC_CONFIRM_TOKEN=SYNC_OBSIDIAN
GRAPHIFY_EXPORT_PATH=./data/live/exports/graphify-map.json
JARVIS_SCHEDULER_ENABLED=false
JARVIS_SCHEDULER_INTERVAL_MS=60000

# WhatsApp Business Cloud API. No secrets in code.
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_REAL_SEND_ENABLED=false
WHATSAPP_SEND_CONFIRM_TOKEN=CONFIRM_SEND
WHATSAPP_BRIDGE_SEND_CONFIRM_TOKEN=CONFIRM_BRIDGE_SEND
WHATSAPP_VERIFY_TOKEN=change-this-webhook-token
WHATSAPP_APP_SECRET=

# Personal desk — notes/priorities JSON under data/$JARVIS_DATA_PROFILE/personal/
# Comma-separated names for `open -a` (macOS). Empty list disables open-app (403).
JARVIS_OPEN_APP_ALLOWLIST=
# Optional: require this exact token in POST /api/personal/open-app body { confirmToken }.
# JARVIS_OPEN_APP_CONFIRM_TOKEN=
# CI / non-macOS: set to true to skip launching apps (still requires allowlist).
# JARVIS_OPEN_APP_DRY_RUN=false
