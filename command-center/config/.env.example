JARVIS_HOME=/Users/user/projects/JARVIS_COMMAND_CENTER
JARVIS_MODE=local
JARVIS_DATA_PROFILE=live
JARVIS_AUDIT_LOG=./data/live/logs/audit.jsonl
JARVIS_DRAFT_STORE=./data/live/drafts/whatsapp-drafts.json
JARVIS_MEMORY_STORE=./data/live/memory/local-memory.json
JARVIS_MISSION_STORE=./data/live/memory/missions.json
JARVIS_INBOX_STORE=./data/live/memory/whatsapp-inbox.json
JARVIS_SCHEDULER_STORE=./data/live/drafts/scheduled-jobs.json
JARVIS_ADAPTERS_ENABLED=
JARVIS_ADAPTER_OBSIDIAN_ENABLED=false
JARVIS_ADAPTER_RUFLO_ENABLED=false
JARVIS_ADAPTER_HERMES_ENABLED=false
JARVIS_ADAPTER_GOOD_MOOD_ENABLED=false
JARVIS_INTENT_ROUTER_MODE=hybrid
JARVIS_INTENT_ROUTER_MIN_CONFIDENCE=0.65
JARVIS_CONFIRM_TOKEN_TTL_MS=120000
JARVIS_CONFIRM_TOKEN_MAX_TTL_MS=900000
JARVIS_RESTORE_CONFIRM_TOKEN=RESTORE_JARVIS
OBSIDIAN_VAULT_PATH=
OBSIDIAN_WRITE_ENABLED=false
OBSIDIAN_SYNC_CONFIRM_TOKEN=SYNC_OBSIDIAN
GRAPHIFY_EXPORT_PATH=./data/live/exports/graphify-map.json
JARVIS_SCHEDULER_ENABLED=false
JARVIS_SCHEDULER_INTERVAL_MS=60000

# WhatsApp Business Cloud API. No secrets in code.
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_REAL_SEND_ENABLED=false
WHATSAPP_SEND_CONFIRM_TOKEN=CONFIRM_SEND
WHATSAPP_BRIDGE_SEND_CONFIRM_TOKEN=CONFIRM_BRIDGE_SEND
WHATSAPP_VERIFY_TOKEN=change-this-webhook-token
WHATSAPP_APP_SECRET=
